APP_NAME="School Management E2E"
APP_ENV=e2e
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
DB_DATABASE="database/e2e.sqlite"

LOG_CHANNEL=stderr
